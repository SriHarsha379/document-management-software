PORT=3001
DATABASE_URL="file:./dev.db"
OPENAI_API_KEY=your_openai_api_key_here
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Driver portal auth ─────────────────────────────────────────────────────────
# Secret used to sign/verify driver JWT tokens — change this in production!
JWT_SECRET=change-me-in-production

# ── Customer portal auth ────────────────────────────────────────────────────────
# Separate secret for customer portal JWTs — change this in production!
CUSTOMER_JWT_SECRET=customer-change-me-in-production

# ── Email dispatch (nodemailer) ────────────────────────────────────────────────
SMTP_HOST=mail.hasafarm.com
SMTP_PORT=587
SMTP_USER=contact@hasafarm.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Logistics DMS <contact@hasafarm.com>"

# ── WhatsApp dispatch (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number

# Public URL for backend (used to generate WhatsApp media attachment URLs)
BACKEND_PUBLIC_URL=http://localhost:3001
