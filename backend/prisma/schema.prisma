// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── RBAC + Org models ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  branches Branch[]
  lrs      Lr[]

  // Master data
  transporters   Transporter[]
  officers       Officer[]
  parties        Party[]
  products       Product[]
  workingCentres WorkingCentre[]

  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBranchAccess UserBranchAccess[]
  lrs              Lr[]
  workingCentres   WorkingCentre[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRoles        UserRole[]
  userBranchAccess UserBranchAccess[]
  userSourceAccess UserSourceAccess[]

  @@map("users")
}

model Role {
  id       String  @id @default(uuid())
  key      String  @unique
  name     String
  isSystem Boolean @default(false)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserBranchAccess {
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branch_access")
}

model UserSourceAccess {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source String

  @@id([userId, source])
  @@map("user_source_access")
}

// ── LR (Lorry Receipt) ────────────────────────────────────────────────────────

model Lr {
  id        String   @id @default(uuid())
  serialNo  Int?     // auto-assigned per-company in application layer

  // Core LR fields
  lrNo              String
  lrDate            String?   // LR date (alias for date)
  loadingSlipNo     String?

  // Invoice / E-Way Bill
  companyInvoiceDate  String?
  companyInvoiceNo    String?
  companyEwayBillNo   String?

  // Parties
  principalCompany    String?
  billToParty         String?   // consignee
  shipToParty         String?
  deliveryDestination String?

  // Transport
  tpt               String?   // transport company short name
  orderType         String?
  productName       String?
  vehicleNo         String?
  quantityInBags    Float?
  quantityInMt      Float?

  // Charges
  tollCharges       Float?
  weighmentCharges  Float?
  unloadingAtSite   Float?
  driverBhatta      Float?

  // Km / Fuel
  dayOpeningKm      Float?
  dayClosingKm      Float?
  totalRunningKm    Float?
  fuelPerKm         Float?
  fuelAmount        Float?
  grandTotal        Float?

  // Transporter / Driver billing
  tptCode           String?
  transporterName   String?
  driverName        String?
  driverBillNo      String?
  billDate          String?
  billNo            String?
  billAmount        Float?

  // Legacy / derived fields kept for backward-compat
  invoiceNo String?
  status    String   @default("DRAFT")
  consignor String?
  consignee String?
  date      String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Row-level access scope columns
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])
  source    String  @default("INTERNAL")

  documentLinks DocumentLinkRecord[]

  @@index([companyId])
  @@index([lrNo])
  @@index([vehicleNo])
  @@index([date])
  @@index([serialNo])

  @@map("lrs")
}

// Groups documents that share the same vehicle number and date
model DocumentGroup {
  id         String     @id @default(uuid())
  vehicleNo  String
  date       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  documents           Document[]
  bundles             DocumentBundle[]
  driverUploadedDocs  DriverUploadDocument[]

  @@unique([vehicleNo, date])
  @@map("document_groups")
}

model Document {
  id               String         @id @default(uuid())
  type             DocumentType
  status           DocumentStatus @default(PENDING_REVIEW)
  originalFilename String
  rawFilePath      String
  mimeType         String
  uploadedAt       DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  groupId       String?
  group         DocumentGroup? @relation(fields: [groupId], references: [id])

  extractedData ExtractedData?

  bundleItems   BundleItem[]

  documentLinks DocumentLinkRecord[]

  @@index([type])
  @@index([status])
  @@index([uploadedAt])

  @@map("documents")
}

model ExtractedData {
  id         String   @id @default(uuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Core logistics fields
  lrNo         String?
  invoiceNo    String?
  vehicleNo    String?
  quantity     String?
  date         String?
  partyNames   String?  // JSON array stored as string in SQLite
  tollAmount   String?
  weightInfo   String?
  transporter  String?  // transporter / transport company name

  // OCR metadata
  rawOcrResponse  String  // Full JSON response from OpenAI stored as string
  confidence      Float?
  ocrProcessedAt  DateTime @default(now())

  // User review
  userReviewed    Boolean  @default(false)
  reviewedAt      DateTime?
  userEdits       String?  // JSON object with fields the user changed

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Indexes for fast filtered searches
  @@index([vehicleNo])
  @@index([lrNo])
  @@index([invoiceNo])
  @@index([date])
  @@index([transporter])

  @@map("extracted_data")
}

// Document bundle for a specific recipient type
model DocumentBundle {
  id            String        @id @default(uuid())
  recipientType RecipientType
  status        BundleStatus  @default(DRAFT)
  notes         String?
  groupId       String
  group         DocumentGroup @relation(fields: [groupId], references: [id])
  items         BundleItem[]
  dispatchLogs  DispatchLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("document_bundles")
}

// Individual document items within a bundle
model BundleItem {
  id         String         @id @default(uuid())
  bundleId   String
  bundle     DocumentBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  documentId String
  document   Document       @relation(fields: [documentId], references: [id])
  isOverride Boolean        @default(false) // true if manually toggled vs. auto-selected

  @@unique([bundleId, documentId])
  @@map("bundle_items")
}

enum DocumentType {
  LR
  INVOICE
  TOLL
  WEIGHMENT
  EWAYBILL
  RECEIVING
  UNKNOWN
}

enum DocumentStatus {
  PENDING_OCR
  PENDING_REVIEW
  REVIEWED
  SAVED
}

enum RecipientType {
  ACCOUNTS
  PARTY
  TRANSPORTER
}

enum BundleStatus {
  DRAFT
  READY
  SENT
}

// Dispatch log: tracks every send attempt (email or WhatsApp) for a bundle
model DispatchLog {
  id          String          @id @default(uuid())
  bundleId    String
  bundle      DocumentBundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  channel     DispatchChannel
  recipient   String          // email address or phone number
  ccRecipient String?         // auto-CC'd email/phone
  message     String          // generated message body
  status      DispatchStatus  @default(PENDING)
  errorMsg    String?
  sentAt      DateTime        @default(now())

  @@map("dispatch_logs")
}

enum DispatchChannel {
  EMAIL
  WHATSAPP
}

enum DispatchStatus {
  PENDING
  SENT
  FAILED
}

// ── Temporary Driver Access ────────────────────────────────────────────────────

model TemporaryDriverAccess {
  id           String    @id @default(uuid())
  phone        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  lastLoginAt  DateTime?
  isRevoked    Boolean   @default(false)

  uploadedDocs DriverUploadDocument[]

  @@map("temporary_driver_accesses")
}

enum DriverDocType {
  LR
  TOLL
  WEIGHMENT_SLIP
}

enum DriverUploadStatus {
  PENDING_OCR
  PROCESSED
  UNLINKED
}

model DriverUploadDocument {
  id               String             @id @default(uuid())
  docType          DriverDocType
  storageKey       String
  originalFilename String
  mimeType         String
  uploadedAt       DateTime           @default(now())
  status           DriverUploadStatus @default(PENDING_OCR)

  // OCR outputs
  ocrText       String?
  ocrData       String?  // full JSON from OpenAI
  vehicleNumber String?
  documentDate  String?

  // Linking
  linkedGroupId String?
  linkedGroup   DocumentGroup? @relation(fields: [linkedGroupId], references: [id])

  // Ownership
  tempDriverAccessId String
  tempDriverAccess   TemporaryDriverAccess @relation(fields: [tempDriverAccessId], references: [id])

  @@map("driver_upload_documents")
}

// ── Advanced Search — Saved Filters ──────────────────────────────────────────

// Persists a user's named search filter set so they can re-run it quickly.
model SavedFilter {
  id        String   @id @default(uuid())
  userId    String
  name      String
  filters   String   // JSON-serialised AdvancedSearchFilters object
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_filters")
}

// ── Master Data ───────────────────────────────────────────────────────────────
// All master entities are scoped to a company. Soft-deletes via isActive flag
// preserve referential integrity when records are in use.

model Transporter {
  id          String   @id @default(uuid())
  code        String   // unique within company
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([isActive])
  @@map("transporters")
}

model Officer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  role      String?  // free-text job title / designation
  isActive  Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([isActive])
  @@map("officers")
}

model Party {
  id            String   @id @default(uuid())
  code          String   // unique within company
  name          String
  contactPerson String?
  phone         String?
  email         String?
  gstNo         String?
  address       String?
  isActive      Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customerPortalAccesses CustomerPortalAccess[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([isActive])
  @@map("parties")
}

// ── Customer Portal Access ────────────────────────────────────────────────────

model CustomerPortalAccess {
  id          String    @id @default(uuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id])
  loginEmail  String    @unique
  tokenHash   String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  lastLoginAt DateTime?
  isRevoked   Boolean   @default(false)

  @@map("customer_portal_accesses")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  brand     String?
  category  String?
  unit      String?  // e.g., KG, MT, BAG, LITRE
  isActive  Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name, brand])
  @@index([companyId])
  @@index([category])
  @@index([isActive])
  @@map("products")
}

model WorkingCentre {
  id        String   @id @default(uuid())
  code      String   // unique within company
  name      String
  address   String?
  isActive  Boolean  @default(true)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@map("working_centres")
}

// ── Communication Module ──────────────────────────────────────────────────────

// Per-company settings for centralized sending addresses
model CompanySettings {
  companyId      String  @id
  smtpFrom       String? // override global SMTP_FROM for this company
  whatsappFrom   String? // override global TWILIO_WHATSAPP_FROM for this company
  defaultCCEmail String? // always CC this email on every outgoing email
  defaultCCPhone String? // always CC this phone on every outgoing WhatsApp

  @@map("company_settings")
}

// Reusable message templates (Handlebars syntax)
model MessageTemplate {
  id              String   @id @default(uuid())
  companyId       String
  code            String   // unique within company
  name            String
  channel         CommChannel @default(BOTH)
  subjectTemplate String?  // for EMAIL channel; supports {{vars}}
  bodyTemplate    String   // Handlebars body; supports {{vars}}
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false) // one default per company+channel
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobs CommunicationJob[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([isActive])
  @@map("message_templates")
}

// Durable queue record — one per send request (may fan out to N messages)
model CommunicationJob {
  id           String      @id @default(uuid())
  companyId    String
  bundleId     String?
  channel      CommChannel
  recipients   String      // JSON: ResolvedRecipient[]
  templateId   String?
  template     MessageTemplate? @relation(fields: [templateId], references: [id])
  templateVars String      @default("{}") // JSON: Record<string,string>
  status       JobStatus   @default(QUEUED)
  priority     JobPriority @default(NORMAL)
  scheduledAt  DateTime    @default(now())
  processedAt  DateTime?
  retryCount   Int         @default(0)
  maxRetries   Int         @default(3)
  lastError    String?
  notes        String?     // warnings from recipient resolution
  createdBy    String?     // userId of the sender
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  messages CommunicationMessage[]

  @@index([companyId])
  @@index([status])
  @@index([scheduledAt])
  @@index([bundleId])
  @@map("communication_jobs")
}

// One row per individual send attempt (fan-out from CommunicationJob)
model CommunicationMessage {
  id              String      @id @default(uuid())
  jobId           String
  job             CommunicationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  channel         CommChannel
  recipient       String      // email address or E.164 phone
  recipientName   String?
  isCC            Boolean     @default(false)
  renderedSubject String?
  renderedBody    String
  mediaUrls       String      @default("[]") // JSON: string[]
  status          MsgStatus   @default(PENDING)
  attemptCount    Int         @default(0)
  lastAttemptAt   DateTime?
  sentAt          DateTime?
  errorCode       String?
  errorMsg        String?
  externalId      String?     // Twilio SID or SMTP messageId
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([recipient])
  @@map("communication_messages")
}

enum CommChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum JobPriority {
  HIGH
  NORMAL
  LOW
}

enum MsgStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ── Document → LR auto-linking ────────────────────────────────────────────────

// Tracks every link between an uploaded Document and an Lr record.
// A document can be linked to multiple LRs (e.g. consolidated shipment).
// A unique constraint prevents duplicate links for the same document+lr pair.
model DocumentLinkRecord {
  id            String   @id @default(uuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lrId          String
  lr            Lr       @relation(fields: [lrId], references: [id], onDelete: Cascade)

  // Which extracted fields caused this match (JSON array, e.g. ["lrNo"] or ["vehicleNo","date"])
  matchedFields String

  // Confidence score 0.0–1.0; ≥ 0.6 is auto-linked, < 0.6 is pending review
  confidence    Float    @default(0.5)

  // true when a user created the link manually (overrides the auto-link result)
  isManual      Boolean  @default(false)

  linkedAt      DateTime @default(now())

  @@unique([documentId, lrId])
  @@map("document_link_records")
}
