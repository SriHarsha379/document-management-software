// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Groups documents that share the same vehicle number and date
model DocumentGroup {
  id         String     @id @default(uuid())
  vehicleNo  String
  date       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  documents  Document[]

  @@unique([vehicleNo, date])
  @@map("document_groups")
}

model Document {
  id               String         @id @default(uuid())
  type             DocumentType
  status           DocumentStatus @default(PENDING_REVIEW)
  originalFilename String
  rawFilePath      String
  mimeType         String
  uploadedAt       DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  groupId       String?
  group         DocumentGroup? @relation(fields: [groupId], references: [id])

  extractedData ExtractedData?

  @@map("documents")
}

model ExtractedData {
  id         String   @id @default(uuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Core logistics fields
  lrNo         String?
  invoiceNo    String?
  vehicleNo    String?
  quantity     String?
  date         String?
  partyNames   String?  // JSON array stored as string in SQLite
  tollAmount   String?
  weightInfo   String?

  // OCR metadata
  rawOcrResponse  String  // Full JSON response from OpenAI stored as string
  confidence      Float?
  ocrProcessedAt  DateTime @default(now())

  // User review
  userReviewed    Boolean  @default(false)
  reviewedAt      DateTime?
  userEdits       String?  // JSON object with fields the user changed

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("extracted_data")
}

enum DocumentType {
  LR
  INVOICE
  TOLL
  WEIGHMENT
  UNKNOWN
}

enum DocumentStatus {
  PENDING_OCR
  PENDING_REVIEW
  REVIEWED
  SAVED
}
